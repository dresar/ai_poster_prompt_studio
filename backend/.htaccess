# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION BEGIN
<IfModule Litespeed>
</IfModule>
# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION END

# 🌐 PERMISSIVE HEADERS & PUBLIC ACCESS FOR AI PROMPT TEXT ENDPOINTS & CRAWLERS
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    Header set Access-Control-Allow-Headers "*"
    Header set X-Robots-Tag "all"
</IfModule>

# Force text/plain MIME type and Allow Public Access for all .txt files
<FilesMatch "\.(txt)$">
    ForceType text/plain
    Header set Content-Type "text/plain; charset=utf-8"
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Explicitly allow unauthenticated public access for /txt directory
<IfModule mod_authz_core.c>
    <Location "/txt">
        Require all granted
    </Location>
    <Location "/prompts">
        Require all granted
    </Location>
</IfModule>
